<UserControl
    x:Class="ShadUI.Demo.Browser.Views.CatalogSidebar"
    x:DataType="demo:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:converters="clr-namespace:ShadUI.Demo.Converters;assembly=shadui-app"
    xmlns:demo="clr-namespace:ShadUI.Demo;assembly=shadui-app"
    xmlns:shadui="clr-namespace:ShadUI;assembly=ShadUI"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <shadui:Sidebar
        Background="{DynamicResource SidebarBackgroundColor}"
        BorderBrush="{DynamicResource BorderColor30}"
        BorderThickness="0,0,1,0"
        CurrentRoute="{Binding CurrentRoute}"
        Expanded="{Binding #SidebarToggler.IsChecked}"
        MinWidth="60"
        Padding="{Binding #SidebarToggler.IsChecked, Converter={x:Static converters:BooleanConverters.SidebarPadding}}"
        Width="220">
        <shadui:Sidebar.ExpandEasing>
            <shadui:EaseInOutBack BounceIntensity="Strong" />
        </shadui:Sidebar.ExpandEasing>

        <shadui:Sidebar.Header>
            <ToggleButton
                CornerRadius="{DynamicResource LgCornerRadius}"
                Height="32"
                HorizontalAlignment="{Binding #SidebarToggler.IsChecked, Converter={x:Static converters:BooleanConverters.SidebarTogglerHorizontalAlignment}}"
                IsChecked="True"
                Name="SidebarToggler"
                Padding="8"
                Theme="{DynamicResource SideTogglerTheme}"
                ToolTip.Tip="Expand or collapse navigation"
                Width="32">
                <Viewbox>
                    <TextBlock Classes="LucideIcon" Text="&#57646;" />
                </Viewbox>
            </ToggleButton>
        </shadui:Sidebar.Header>

        <StackPanel Spacing="4">
            <shadui:SidebarItemLabel AsSeparator="True" Text="Get Started" />
            <shadui:SidebarItem Command="{Binding OpenDashboardCommand}" Content="Dashboard" Route="dashboard">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57793;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenThemeCommand}" Content="Theming" Route="theme">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58088;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenTypographyCommand}" Content="Typography" Route="typography">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58887;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>

            <shadui:SidebarItemLabel AsSeparator="True" Text="Behaviors" />
            <shadui:SidebarItem Command="{Binding OpenSmoothScrollCommand}" Content="Smooth Scroll" Route="smoothScroll">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58583;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>

            <shadui:SidebarItemLabel AsSeparator="True" Text="Components" />
            <shadui:SidebarItem Command="{Binding OpenAvatarCommand}" Content="Avatar" Route="avatar">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58470;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenBadgeCommand}" Content="Badge" Route="badge">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58416;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenButtonsCommand}" Content="Button" Route="button">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57636;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenCardsCommand}" Content="Card" Route="card">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57506;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenCheckBoxesCommand}" Content="CheckBox" Route="checkbox">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58568;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenColorsCommand}" Content="Color" Route="color">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57821;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenComboBoxesCommand}" Content="ComboBox" Route="combobox">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57873;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenDataGridCommand}" Content="Data Table" Route="data-table">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58628;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenDateCommand}" Content="Date Control" Route="date">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57447;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenDialogsCommand}" Content="Dialog" Route="dialog">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57627;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenInputsCommand}" Content="Input" Route="input">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57957;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenMenusCommand}" Content="Menu" Route="menu">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58456;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenNumericsCommand}" Content="Numeric Input" Route="numeric">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="ShadUIIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#xe902;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenSidebarCommand}" Content="Sidebar" Route="sidebar">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57646;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenSlidersCommand}" Content="Slider" Route="slider">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58010;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenSwitchCommand}" Content="Switch" Route="switch">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57739;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenTabsCommand}" Content="Tab Control" Route="tab-control">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58411;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenTimeCommand}" Content="Time" Route="time">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57937;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenToastCommand}" Content="Toast" Route="toast">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57980;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenToggleCommand}" Content="Toggle" Route="toggle">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58751;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenToolTipCommand}" Content="Tooltip" Route="tooltip">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#57626;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
            <shadui:SidebarItem Command="{Binding OpenMiscellaneousCommand}" Content="Miscellaneous" Route="miscellaneous">
                <shadui:SidebarItem.Icon>
                    <Viewbox><TextBlock Classes="LucideIcon" Foreground="{DynamicResource ForegroundColor}" Text="&#58671;" /></Viewbox>
                </shadui:SidebarItem.Icon>
            </shadui:SidebarItem>
        </StackPanel>

        <shadui:Sidebar.Footer>
            <Menu Classes="Single">
                <MenuItem
                    Classes="NoPressedAnimation"
                    CornerRadius="{DynamicResource LgCornerRadius}"
                    HorizontalAlignment="Stretch"
                    Padding="8,0"
                    shadui:MenuItemAssist.PopupHorizontalOffset="4"
                    shadui:MenuItemAssist.PopupPlacement="RightEdgeAlignedBottom"
                    shadui:MenuItemAssist.PopupVerticalOffset="4">
                    <MenuItem.Header>
                        <Panel>
                            <shadui:Avatar
                                CornerRadius="{DynamicResource LgCornerRadius}"
                                Fallback="CN"
                                IsVisible="{Binding !$parent[shadui:Sidebar].Expanded}"
                                Opacity="{Binding !$parent[shadui:Sidebar].Expanded, Converter={x:Static converters:BooleanConverters.Opaque}}"
                                Source="avares://shadui-app/Assets/user.png">
                                <shadui:Avatar.Transitions>
                                    <Transitions>
                                        <DoubleTransition Duration="0:0:0.20" Property="Opacity" />
                                    </Transitions>
                                </shadui:Avatar.Transitions>
                            </shadui:Avatar>
                            <Grid
                                ColumnDefinitions="Auto * Auto"
                                IsVisible="{Binding $parent[shadui:Sidebar].Expanded}"
                                Margin="0,8">
                                <shadui:Avatar
                                    CornerRadius="{DynamicResource XlCornerRadius}"
                                    Fallback="CN"
                                    Height="36"
                                    Margin="0,0,8,0"
                                    Source="avares://shadui-app/Assets/user.png"
                                    Width="36" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Classes="Small" Text="shadui" />
                                    <TextBlock Classes="Caption" Margin="0,-4,0,0" Text="m@example.com" />
                                </StackPanel>
                                <Viewbox Grid.Column="2" Height="16" Width="16">
                                    <TextBlock
                                        Classes="LucideIcon"
                                        Foreground="{DynamicResource ForegroundColor}"
                                        Text="&#57873;" />
                                </Viewbox>
                            </Grid>
                        </Panel>
                    </MenuItem.Header>
                    <shadui:MenuItemAssist.Label>
                        <Grid ColumnDefinitions="Auto *" HorizontalAlignment="Stretch" Width="220">
                            <shadui:Avatar
                                CornerRadius="{DynamicResource XlCornerRadius}"
                                Fallback="CN"
                                Height="36"
                                Margin="0,0,8,0"
                                Source="avares://shadui-app/Assets/user.png"
                                Width="36" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Classes="Small" Text="shadui" />
                                <TextBlock Classes="Caption" Margin="0,-4,0,0" Text="m@example.com" />
                            </StackPanel>
                        </Grid>
                    </shadui:MenuItemAssist.Label>
                    <Separator />
                    <MenuItem Command="{Binding ShowAboutCommand}" Header="About">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57599;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="OnExternalLinkClick"
                        Header="Readme"
                        Tag="https://github.com/accntech/shad-ui?tab=readme-ov-file#readme">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57443;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Click="OnExternalLinkClick" Header="Source repository" Tag="https://github.com/accntech/shad-ui">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57862;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem
                        Click="OnExternalLinkClick"
                        Header="MIT License"
                        Tag="https://github.com/accntech/shad-ui?tab=MIT-1-ov-file#readme">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57874;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="OnExternalLinkClick"
                        Header="Code of Conduct"
                        Tag="https://github.com/accntech/shad-ui?tab=coc-ov-file#readme">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#58071;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem
                        Click="OnExternalLinkClick"
                        Header="Security"
                        Tag="https://github.com/accntech/shad-ui?tab=security-ov-file">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57692;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Click="OnExternalLinkClick" Header="Activity" Tag="https://github.com/accntech/shad-ui/activity">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock Classes="LucideIcon" Foreground="{DynamicResource MutedColor}" Text="&#57400;" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator />
                    <MenuItem Command="{Binding SwitchThemeCommand}" Header="Switch theme">
                        <MenuItem.Icon>
                            <Viewbox Height="16" Width="16">
                                <TextBlock
                                    Classes="LucideIcon"
                                    Foreground="{DynamicResource MutedColor}"
                                    Text="{Binding CurrentTheme, Converter={x:Static converters:ThemeModeConverters.ToLucideIcon}}" />
                            </Viewbox>
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </shadui:Sidebar.Footer>
    </shadui:Sidebar>
</UserControl>
